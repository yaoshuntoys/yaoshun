# 站点配置
# 网站公开访问地址，用于 SEO、站点地图、元信息和绝对链接。
NEXT_PUBLIC_SITE_URL=https://www.yaoshuntoys.com

# Google / 广告
# Google Analytics 衡量 ID，例如 G-XXXXXXXXXX。
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
# Google Ads 标签 ID，例如 AW-123456789。
NEXT_PUBLIC_GOOGLE_ADS_ID=
# Google Ads 询盘转化目标，通常是 AW-xxx/label。
NEXT_PUBLIC_GOOGLE_ADS_LEAD_CONVERSION_SEND_TO=
# 可选：联系按钮点击的独立 Google Ads 转化目标。
NEXT_PUBLIC_GOOGLE_ADS_CONTACT_CONVERSION_SEND_TO=
# 上报询盘转化时使用的货币代码。
NEXT_PUBLIC_GOOGLE_ADS_LEAD_CONVERSION_CURRENCY=USD
# 上报询盘转化时使用的数值。
NEXT_PUBLIC_GOOGLE_ADS_LEAD_CONVERSION_VALUE=1
# Google Search Console 站点验证 token，会暴露到前端。
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Google Search Console 站点验证 token 的服务端兜底配置。
GOOGLE_SITE_VERIFICATION=
# 本地调试时可设为 false 关闭第三方追踪脚本。
NEXT_PUBLIC_ENABLE_THIRD_PARTY_TRACKING=true

# 询盘收件人
# 网站询盘主收件邮箱。
CONTACT_FORM_TO_EMAIL=yaoshuntoys@gmail.com
# SMTP 额外收件邮箱；不确定时可与主收件邮箱保持一致。
SMTP_TO_EMAIL=
# Tawk.to 工单邮箱，用于通过 SMTP 创建客服工单。
TAWK_TICKET_EMAIL=

# SMTP 邮件通道
# Nodemailer 使用的 SMTP 服务器地址。
EMAIL_HOST=
# SMTP 端口；465 会自动使用 TLS。
EMAIL_PORT=
# SMTP 登录用户名。
EMAIL_USER=
# SMTP 登录密码或应用专用密码。
EMAIL_PASS=
# SMTP 服务商允许使用的发件邮箱。
EMAIL_FROM=

# Resend 邮件通道
# Resend API Key，用于并行发送询盘邮件。
RESEND_API_KEY=
# Resend 发件邮箱；生产环境建议使用已验证域名邮箱以提高送达率。
RESEND_FROM_EMAIL=onboarding@resend.dev
# Resend 邮件副本收件邮箱。
RESEND_TO_EMAIL=yaoshuntoys@gmail.com
