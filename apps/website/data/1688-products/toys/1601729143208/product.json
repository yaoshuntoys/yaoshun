  "productDetails": [
    {
      "sectionTitle": {
        "en": "Castle Tent Builds",
        "zh": "城堡帐篷搭建"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601729143208/1.webp",
      "text": {
        "en": "House-and-side-room structures give children more story space and make the set useful for playrooms and education corners.",
        "zh": "房屋加侧房结构提供更多故事空间，适合游戏室和教育角落使用。"
      }
    },
    {
      "sectionTitle": {
        "en": "Gift Retail Identity",
        "zh": "礼品零售属性"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601729143208/2.webp",
      "text": {
        "en": "Bright packaging supports family channels, seasonal promotions, and easy online product presentation.",
        "zh": "明亮包装适合家庭渠道、季节促销和线上销售页面。"
      }
    },
    {
      "sectionTitle": {
        "en": "Safe Family Interaction",
        "zh": "安全亲子互动"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601729143208/3.webp",
      "text": {
        "en": "Stable rectangular frames create an easy entry point for parents and children to build and play together.",
        "zh": "稳定矩形框架为亲子共同搭建和玩耍提供简单入口。"
      }
    },
    {
      "sectionTitle": {
        "en": "Expandable Playhouse",
        "zh": "可扩展游戏屋"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601729143208/4.webp",
      "text": {
        "en": "Multiple connected bays help children extend the structure into a larger house, tunnel, or imaginative room layout.",
        "zh": "多个连接分区帮助儿童将结构扩展成更大的房屋、通道或创意房间布局。"
      }
    },
    {
      "sectionTitle": {
        "en": "Packed for Reuse",
        "zh": "便于重复使用的包装"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601729143208/5.webp",
      "text": {
        "en": "Bag, rods, balls, and guide materials support easier cleanup, storage, and repeated play after each activity.",
        "zh": "布袋、杆件、球体和说明资料便于每次活动后的整理、收纳和重复玩耍。"
      }
    }
