  "productDetails": [
    {
      "sectionTitle": {
        "en": "Pink-Purple Build Style",
        "zh": "粉紫拼搭风格"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601730435470/1.webp",
      "text": {
        "en": "Soft pink and purple parts create a warmer indoor look while keeping the structure clear for parent-child assembly.",
        "zh": "柔和粉紫配件营造更温暖的室内观感，同时结构清晰，便于亲子共同拼搭。"
      }
    },
    {
      "sectionTitle": {
        "en": "Stable Roofed Playhouse",
        "zh": "稳定屋顶游戏屋"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601730435470/2.webp",
      "text": {
        "en": "Rotating ball connectors make angled roof sections easier to adjust, helping children build a compact playhouse for living rooms.",
        "zh": "旋转球连接件让屋顶角度更容易调整，帮助儿童搭建适合客厅的小型游戏屋。"
      }
    },
    {
      "sectionTitle": {
        "en": "Hexagon Tent Structure",
        "zh": "六边形帐篷结构"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601730435470/3.webp",
      "text": {
        "en": "The upgraded connector system supports wider hexagon-style frames with open interior space for sitting, crawling, and pretend play.",
        "zh": "升级连接系统支持更宽的六边形框架，内部空间适合坐卧、爬行和角色扮演。"
      }
    },
    {
      "sectionTitle": {
        "en": "Early Learning Play Mat Use",
        "zh": "早教游戏垫场景"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601730435470/4.webp",
      "text": {
        "en": "The frame works well on play mats and learning areas, supporting safe indoor interaction, sorting, building, and imaginative games.",
        "zh": "框架适合放在游戏垫和学习区使用，支持安全室内互动、分类、建构和想象游戏。"
      }
    }
  ],
