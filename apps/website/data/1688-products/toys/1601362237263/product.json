  "productDetails": [
    {
      "sectionTitle": {
        "en": "Large Castle Play",
        "zh": "大型城堡玩法"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products/1601362237263/1.webp",
      "text": {
        "en": "The expanded frame gives children a stronger sense of scale and turns cooperative building into a shared pretend-play activity.",
        "zh": "扩展框架带来更强尺寸感，让协作拼搭转化为共同角色扮演活动。"
      }
    },
    {
      "sectionTitle": {
        "en": "DIY Fort Retail Box",
        "zh": "DIY堡垒彩盒"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products/1601362237263/2.webp",
      "text": {
        "en": "Gift-oriented packaging supports family channels, seasonal displays, and branded retail programs.",
        "zh": "礼品化包装适合家庭渠道、季节陈列和品牌零售项目。"
      }
    },
    {
      "sectionTitle": {
        "en": "Classic Roof Structure",
        "zh": "经典屋顶结构"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products/1601362237263/3.webp",
      "text": {
        "en": "Balanced roof and wall sections create a reliable standard build for product demonstrations and instruction materials.",
        "zh": "平衡的屋顶与墙体结构可作为产品演示和说明资料中的标准搭建方案。"
      }
    },
    {
      "sectionTitle": {
        "en": "Open Interior Space",
        "zh": "开放内部空间"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products/1601362237263/4.webp",
      "text": {
        "en": "The taller frame gives children room to stand, move, and interact, making the play experience more active.",
        "zh": "较高框架为儿童站立、移动和互动提供空间，让玩耍体验更主动。"
      }
    },
    {
      "sectionTitle": {
        "en": "Durable Blue Parts",
        "zh": "耐用蓝色配件"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products/1601362237263/5.webp",
      "text": {
        "en": "Blue rods and two-color connector balls offer a clear, durable, and easy-to-repeat building system for bulk toy programs.",
        "zh": "蓝色杆件与双色连接球形成清晰、耐用、易复用的拼搭系统，适合批量玩具项目。"
      }
    }
  ],
