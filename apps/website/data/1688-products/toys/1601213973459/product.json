  "productDetails": [
    {
      "sectionTitle": {
        "en": "Compact Secret Base",
        "zh": "小型秘密基地"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products/1601213973459/1.webp",
      "text": {
        "en": "The frame can be covered with fabric or lights to create a cozy hideout for reading, storytelling, and pretend play.",
        "zh": "框架可覆盖布料或灯串，形成适合阅读、讲故事和角色扮演的温馨小基地。"
      }
    },
    {
      "sectionTitle": {
        "en": "Compact Gift Box",
        "zh": "小巧礼品彩盒"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products/1601213973459/2.webp",
      "text": {
        "en": "The box format is suitable for entry-level fort programs where buyers need gift appeal, clear sizing, and efficient shipping.",
        "zh": "彩盒形式适合入门级堡垒项目，兼顾礼品感、尺寸清晰和运输效率。"
      }
    },
    {
      "sectionTitle": {
        "en": "Frame and Parts Set",
        "zh": "框架与配件组合"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products/1601213973459/3.webp",
      "text": {
        "en": "Rods, connector balls, storage bag, and guide materials give buyers a complete view of how the set is packed and used.",
        "zh": "杆件、连接球、收纳袋和说明资料组成完整配置，便于采购理解包装与使用方式。"
      }
    },
    {
      "sectionTitle": {
        "en": "Rounded PP Connectors",
        "zh": "圆润PP连接件"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products/1601213973459/4.webp",
      "text": {
        "en": "Rounded connector holes and smooth poles make assembly more comfortable for young children while supporting repeated rebuilding.",
        "zh": "圆润连接孔和平滑杆件让低龄儿童拼接更舒适，并支持反复重建。"
      }
    },
    {
      "sectionTitle": {
        "en": "Open-Ended Building",
        "zh": "开放式拼搭"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products/1601213973459/5.webp",
      "text": {
        "en": "Children can build, take apart, and redesign new shapes with the same basic parts, extending the play value of a compact set.",
        "zh": "儿童可用同一套基础组件反复搭建、拆解和重新设计，提升小套装的持续玩耍价值。"
      }
    }
  ],
