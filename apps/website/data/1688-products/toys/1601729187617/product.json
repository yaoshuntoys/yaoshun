  "productDetails": [
    {
      "sectionTitle": {
        "en": "Cozy Secret Base",
        "zh": "温馨秘密基地"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products/1601729187617/1.webp",
      "text": {
        "en": "A fabric-covered frame turns the construction set into a warm hideout for reading, storytelling, and family play.",
        "zh": "布料覆盖框架可把拼搭套装变成适合阅读、讲故事和家庭互动的温馨小屋。"
      }
    },
    {
      "sectionTitle": {
        "en": "Luminous Theme Package",
        "zh": "夜光主题包装"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products/1601729187617/2.webp",
      "text": {
        "en": "Space-inspired packaging gives the product a clear identity for gift shelves and e-commerce listings.",
        "zh": "太空灵感包装为产品建立清晰识别度，适合礼品货架和电商页面。"
      }
    },
    {
      "sectionTitle": {
        "en": "Tall Geometry Builds",
        "zh": "高几何结构"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products/1601729187617/3.webp",
      "text": {
        "en": "Children can create taller structures and practice how vertical supports and cross connections affect stability.",
        "zh": "儿童可搭建更高结构，并练习理解垂直支撑和交叉连接对稳定性的影响。"
      }
    },
    {
      "sectionTitle": {
        "en": "Outdoor Story Extension",
        "zh": "户外故事延展"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products/1601729187617/4.webp",
      "text": {
        "en": "The glow-style structure also works for yard, patio, or camping-themed promotions, extending the product beyond bedroom use.",
        "zh": "夜光风格结构也适合庭院、露台或露营主题推广，将产品场景延伸出卧室。"
      }
    },
    {
      "sectionTitle": {
        "en": "Nighttime Gift Appeal",
        "zh": "夜间礼品吸引力"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products/1601729187617/5.webp",
      "text": {
        "en": "Low-light play creates a more memorable experience for children and strengthens the emotional value of the set.",
        "zh": "暗光玩法为儿童带来更难忘体验，也增强套装的情绪价值和礼品感。"
      }
    }
  ],
