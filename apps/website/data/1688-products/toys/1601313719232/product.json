  "productDetails": [
    {
      "sectionTitle": {
        "en": "Open-Ended House Builds",
        "zh": "开放式房屋搭建"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601313719232/1.webp",
      "text": {
        "en": "Children can build simple house frames and expand them into different shapes, encouraging creativity and early engineering thinking.",
        "zh": "儿童可搭建简单房屋框架并扩展成不同造型，培养创造力和早期工程思维。"
      }
    },
    {
      "sectionTitle": {
        "en": "Real Packed Components",
        "zh": "真实包装配置"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601313719232/2.webp",
      "text": {
        "en": "Balls, rods, storage bag, and instructions are packed for easy checking during sampling, quality review, and buyer approval.",
        "zh": "球体、杆件、收纳袋和说明书配置清晰，便于打样、质检和客户确认。"
      }
    },
    {
      "sectionTitle": {
        "en": "Shared Play Space",
        "zh": "共享游戏空间"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601313719232/3.webp",
      "text": {
        "en": "The assembled playhouse offers enough space for two children, supporting cooperative building and story-based play.",
        "zh": "成品游戏屋可容纳两个孩子互动，支持协作拼搭和故事化玩法。"
      }
    },
    {
      "sectionTitle": {
        "en": "Specification Clarity",
        "zh": "规格清晰"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601313719232/4.webp",
      "text": {
        "en": "Pole lengths, connector counts, and stability icons make it easier for buyers to compare versions and plan replenishment.",
        "zh": "杆长、连接球数量和稳定性图标便于采购对比版本并规划补货。"
      }
    },
    {
      "sectionTitle": {
        "en": "OEM Color Options",
        "zh": "OEM配色选择"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601313719232/5.webp",
      "text": {
        "en": "Alternative pole and connector colors can support private-label projects, seasonal themes, and differentiated retail lines.",
        "zh": "不同杆件和连接球颜色可支持自有品牌、季节主题和差异化零售系列。"
      }
    }
  ],
