  "productDetails": [
    {
      "sectionTitle": {
        "en": "Cozy Tent Building",
        "zh": "温馨帐篷搭建"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1600900125789/1.webp",
      "text": {
        "en": "Children can cover the frame with fabric or lights to create a reading nook, secret base, or quiet pretend-play corner.",
        "zh": "儿童可在框架外覆盖布料或灯串，打造阅读角、秘密基地或安静的角色扮演角落。"
      }
    },
    {
      "sectionTitle": {
        "en": "Gift-Ready Box",
        "zh": "礼品化彩盒"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1600900125789/2.webp",
      "text": {
        "en": "The Starry Sky Dreamer packaging gives the set a strong gifting identity for online shops, holiday promotions, and retail shelves.",
        "zh": "Starry Sky Dreamer 包装强化礼品属性，适合线上店铺、节日促销和零售货架。"
      }
    },
    {
      "sectionTitle": {
        "en": "Clear Parts Planning",
        "zh": "清晰配件配置"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1600900125789/3.webp",
      "text": {
        "en": "Defined pole and connector counts help buyers confirm set value, carton planning, and replacement-part requirements before production.",
        "zh": "明确的杆件和连接球数量便于采购在生产前确认套装价值、装箱方案和补件需求。"
      }
    },
    {
      "sectionTitle": {
        "en": "Room-Size Play Space",
        "zh": "房间级游戏空间"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1600900125789/4.webp",
      "text": {
        "en": "The kit can form wider structures with multiple play zones, making it suitable for siblings, friends, and story-based group play.",
        "zh": "套装可形成更宽的多区域结构，适合兄弟姐妹、朋友和故事化多人游戏。"
      }
    },
    {
      "sectionTitle": {
        "en": "Flexible Geometry",
        "zh": "灵活几何造型"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1600900125789/5.webp",
      "text": {
        "en": "Beyond standard house frames, children can build dome and rounded structures that make the product feel more open-ended.",
        "zh": "除标准房屋框架外，儿童还可搭建圆顶和弧形结构，让产品更具开放式创造空间。"
      }
    }
  ],
