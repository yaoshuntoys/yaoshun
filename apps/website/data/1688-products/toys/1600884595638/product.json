  "productDetails": [
    {
      "sectionTitle": {
        "en": "Glow Castle Play",
        "zh": "发光城堡玩法"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1600884595638/1.webp",
      "text": {
        "en": "Glow rods help children turn a simple frame into a castle-style play space for bedtime stories, pretend play, and family interaction.",
        "zh": "发光杆件可将基础框架变成城堡式游戏空间，适合睡前故事、角色扮演和亲子互动。"
      }
    },
    {
      "sectionTitle": {
        "en": "Retail-Ready Packing",
        "zh": "零售化包装配置"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1600884595638/2.webp",
      "text": {
        "en": "The set includes a color box, storage bag, manual, off-white poles, and orange connector balls for convenient packing review and resale planning.",
        "zh": "套装包含彩盒、收纳袋、说明书、米白杆件和橙色连接球，便于包装核对和零售销售规划。"
      }
    },
    {
      "sectionTitle": {
        "en": "Tall STEM Builds",
        "zh": "高结构STEM搭建"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1600884595638/3.webp",
      "text": {
        "en": "Children can build taller house frames and learn how triangles, roof lines, and support points improve structural stability.",
        "zh": "儿童可搭建更高的房屋框架，并理解三角结构、屋顶线条和支撑点如何提升稳定性。"
      }
    },
    {
      "sectionTitle": {
        "en": "Simple House Assembly",
        "zh": "简易房屋拼搭"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1600884595638/4.webp",
      "text": {
        "en": "The pole-and-ball layout makes the house structure easy to understand, helping children follow patterns and rebuild independently.",
        "zh": "杆球连接方式让房屋结构更易理解，帮助儿童按规律拼接并尝试独立重建。"
      }
    },
    {
      "sectionTitle": {
        "en": "Durable PP Components",
        "zh": "耐用PP组件"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1600884595638/5.webp",
      "text": {
        "en": "Smooth PP rods and perforated connector balls are designed for repeated play, easy gripping, and safer handling by young builders.",
        "zh": "平滑PP杆件和多孔连接球适合反复玩耍，握持方便，也更适合低龄儿童安全操作。"
      }
    }
  ],
