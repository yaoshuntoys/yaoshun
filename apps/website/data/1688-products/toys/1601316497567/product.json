  "productDetails": [
    {
      "sectionTitle": {
        "en": "Glow Tent Play",
        "zh": "夜光帐篷玩法"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601316497567/1.webp",
      "text": {
        "en": "Glow-style rods add a playful atmosphere for reading corners, bedtime games, and family gift programs.",
        "zh": "夜光风格杆件为阅读角、睡前游戏和家庭礼品项目增加趣味氛围。"
      }
    },
    {
      "sectionTitle": {
        "en": "Child-Friendly Scale",
        "zh": "儿童友好尺寸"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601316497567/2.webp",
      "text": {
        "en": "The frame height is approachable for children and gives buyers a practical sense of indoor playhouse scale.",
        "zh": "框架高度适合儿童使用，也让采购更直观判断室内游戏屋尺寸。"
      }
    },
    {
      "sectionTitle": {
        "en": "Quick Triangle Builds",
        "zh": "快速三角搭建"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601316497567/3.webp",
      "text": {
        "en": "Triangular forms are stable and easy to learn, making them useful for beginner STEM activities and parent-guided play.",
        "zh": "三角结构稳定且易学，适合入门STEM活动和成人引导下的亲子拼搭。"
      }
    },
    {
      "sectionTitle": {
        "en": "Vertical Building Challenge",
        "zh": "纵向搭建挑战"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601316497567/4.webp",
      "text": {
        "en": "Tower structures let children test height, balance, and connection strength while keeping the activity playful.",
        "zh": "高塔结构让儿童在游戏中尝试高度、平衡和连接强度。"
      }
    },
    {
      "sectionTitle": {
        "en": "Simple Parts Count",
        "zh": "简明配件数量"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601316497567/5.webp",
      "text": {
        "en": "Clear rod and connector quantities help buyers evaluate set value, replacement needs, and retail version planning.",
        "zh": "清晰的杆件和连接球数量便于采购评估套装价值、补件需求和零售版本规划。"
      }
    }
  ],
