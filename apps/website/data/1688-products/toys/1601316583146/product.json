  "productDetails": [
    {
      "sectionTitle": {
        "en": "Wide Arched Fort",
        "zh": "宽拱形堡垒"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601316583146/1.webp",
      "text": {
        "en": "A wider arched format gives children room to enter, crawl, and play together, increasing activity value beyond static building.",
        "zh": "更宽的拱形结构让儿童可以进入、爬行和共同玩耍，提升静态拼搭之外的活动价值。"
      }
    },
    {
      "sectionTitle": {
        "en": "Outdoor Gift Appeal",
        "zh": "户外礼品感"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601316583146/2.webp",
      "text": {
        "en": "Family-yard and picnic styling helps position the set for seasonal promotions, outdoor toy displays, and gift campaigns.",
        "zh": "庭院和野餐风格有助于产品进入季节促销、户外玩具陈列和礼品推广。"
      }
    },
    {
      "sectionTitle": {
        "en": "158-Piece Content Set",
        "zh": "158件内容配置"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601316583146/3.webp",
      "text": {
        "en": "Blue rods and two-color connector balls create a richer building set for larger structures and more varied shapes.",
        "zh": "蓝色杆件与双色连接球组成更丰富的拼搭配置，支持更大结构和更多造型变化。"
      }
    },
    {
      "sectionTitle": {
        "en": "Complete House Frame",
        "zh": "完整房屋框架"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601316583146/4.webp",
      "text": {
        "en": "A finished house frame works well without fabric, giving retailers a clean reference build for product pages and buyer presentations.",
        "zh": "完整房屋框架无需布料也具备成品效果，适合零售页面和展厅作为标准参考结构。"
      }
    },
    {
      "sectionTitle": {
        "en": "Rounded Shape Options",
        "zh": "圆角造型选择"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601316583146/5.webp",
      "text": {
        "en": "The rod-and-ball system can form softer rounded structures, giving children more design choices than standard square houses.",
        "zh": "杆球系统可形成更柔和的圆角结构，为儿童提供比标准方形房屋更多的设计选择。"
      }
    }
  ],
