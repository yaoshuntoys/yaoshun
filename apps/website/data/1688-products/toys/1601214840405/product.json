  "productDetails": [
    {
      "sectionTitle": {
        "en": "Indoor Playhouse",
        "zh": "室内游戏屋"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products/1601214840405/1.webp",
      "text": {
        "en": "The construction frame can become a fabric-covered playhouse for quiet play, story time, and parent-child interaction.",
        "zh": "拼搭框架可变成布料覆盖的室内游戏屋，适合安静玩耍、故事时间和亲子互动。"
      }
    },
    {
      "sectionTitle": {
        "en": "120-Piece Configuration",
        "zh": "120件配置"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products/1601214840405/2.webp",
      "text": {
        "en": "Blue poles, blue connector balls, green connector balls, storage bag, and guide materials create a complete ready-to-build set.",
        "zh": "蓝色杆件、蓝色连接球、绿色连接球、收纳袋和说明资料组成完整即开即搭套装。"
      }
    },
    {
      "sectionTitle": {
        "en": "Tent Frame Use",
        "zh": "帐篷骨架用途"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products/1601214840405/3.webp",
      "text": {
        "en": "The assembled frame works as a base for themed covers, giving retailers more bundle ideas for fort and kids-tent programs.",
        "zh": "成品框架可作为主题布套骨架，为零售商提供堡垒和儿童帐篷组合销售思路。"
      }
    },
    {
      "sectionTitle": {
        "en": "Bedroom Hideout",
        "zh": "卧室秘密基地"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products/1601214840405/4.webp",
      "text": {
        "en": "A darker fabric cover creates a stronger hideout feeling, making the product suitable for bedroom play corners and gift bundles.",
        "zh": "深色布套可营造更强秘密基地感，适合卧室游戏角和礼品组合。"
      }
    },
    {
      "sectionTitle": {
        "en": "Tall Roof Structure",
        "zh": "高屋顶结构"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products/1601214840405/5.webp",
      "text": {
        "en": "The triangular roof design helps children understand support points and creates a recognizable house shape without extra accessories.",
        "zh": "三角屋顶设计帮助儿童理解支撑点，也能在不加配件时形成清晰房屋造型。"
      }
    }
  ],
