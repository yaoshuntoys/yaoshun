  "productDetails": [
    {
      "sectionTitle": {
        "en": "Night Glow Castle",
        "zh": "夜光城堡"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601110728943/1.webp",
      "text": {
        "en": "The glow frame creates an eye-catching castle effect for bedtime play, camping themes, and gift campaigns.",
        "zh": "夜光框架可形成醒目的城堡效果，适合睡前玩耍、露营主题和礼品推广。"
      }
    },
    {
      "sectionTitle": {
        "en": "Retail Package Size",
        "zh": "零售包装尺寸"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601110728943/2.webp",
      "text": {
        "en": "Compact color-box packaging helps buyers plan shelf display, carton loading, online listings, and branded artwork updates.",
        "zh": "紧凑彩盒包装便于规划货架陈列、装箱、电商 listing 和品牌画面更新。"
      }
    },
    {
      "sectionTitle": {
        "en": "Complete Accessory Set",
        "zh": "完整配件套装"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601110728943/3.webp",
      "text": {
        "en": "Storage bag, glow poles, connector balls, guide sheet, and size references support easy inspection before sampling or mass production.",
        "zh": "收纳袋、夜光杆、连接球、说明页和尺寸参考齐全，便于打样或量产前核对。"
      }
    },
    {
      "sectionTitle": {
        "en": "Stable Roof Structures",
        "zh": "稳定屋顶结构"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601110728943/4.webp",
      "text": {
        "en": "Triangular bracing helps children build stronger castle roofs while learning balance, load paths, and spatial relationships.",
        "zh": "三角支撑帮助儿童搭建更稳固的城堡屋顶，同时理解平衡、受力路径和空间关系。"
      }
    },
    {
      "sectionTitle": {
        "en": "Low-Light Play Value",
        "zh": "暗光玩法价值"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601110728943/5.webp",
      "text": {
        "en": "The luminous effect extends play from daytime construction to evening storytelling, creating stronger emotional value for families.",
        "zh": "夜光效果把白天拼搭延伸到夜间故事场景，为家庭使用带来更强情绪价值。"
      }
    }
  ],
