  "productDetails": [
    {
      "sectionTitle": {
        "en": "Colorful Creative Kit",
        "zh": "彩色创意套装"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601724919450/1.webp",
      "text": {
        "en": "The 100-piece configuration gives children enough parts for a bright connector ball tent or make a fort toy structure that feels approachable and giftable.",
        "zh": "100件配置为儿童提供足够组件，可搭建明亮、有趣且具有礼品感的结构。"
      }
    },
    {
      "sectionTitle": {
        "en": "Friendly Retail Design",
        "zh": "亲和零售设计"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601724919450/2.webp",
      "text": {
        "en": "Cartoon-style packaging and clear build ideas make the set easy for parents and children to understand quickly.",
        "zh": "卡通风格包装和清晰搭建示例让家长与儿童一眼理解产品玩法。"
      }
    },
    {
      "sectionTitle": {
        "en": "Classroom Building Value",
        "zh": "课堂搭建价值"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601724919450/3.webp",
      "text": {
        "en": "The kit supports safe group construction, helping children practice planning, connection order, and teamwork.",
        "zh": "套装支持安全的小组搭建，帮助儿童练习规划、连接顺序和团队协作。"
      }
    },
    {
      "sectionTitle": {
        "en": "Home Playhouse Use",
        "zh": "家庭游戏屋用途"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601724919450/4.webp",
      "text": {
        "en": "A house-frame build creates an inviting play space for siblings, friends, and parent-child interaction.",
        "zh": "房屋框架可形成有吸引力的游戏空间，适合兄弟姐妹、朋友和亲子互动。"
      }
    },
    {
      "sectionTitle": {
        "en": "Easy Parts Comparison",
        "zh": "配件易于对比"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601724919450/5.webp",
      "text": {
        "en": "Clear pole and connector quantities help buyers compare specifications and choose the right retail version.",
        "zh": "清晰的杆件与连接球数量便于采购对比规格并选择合适的零售版本。"
      }
    }
