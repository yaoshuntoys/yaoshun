  "productDetails": [
    {
      "sectionTitle": {
        "en": "Complete 130-Piece Kit",
        "zh": "130件完整套装"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601730326005/1.webp",
      "text": {
        "en": "Box, rods, connector balls, guide materials, and themed accessories create a complete retail-ready building set.",
        "zh": "彩盒、杆件、连接球、说明资料和主题配件组成完整的零售化拼搭套装。"
      }
    },
    {
      "sectionTitle": {
        "en": "Glow Tent Experience",
        "zh": "夜光帐篷体验"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601730326005/2.webp",
      "text": {
        "en": "The frame can be covered to create a reading nook, secret base, or night-play shelter for family use.",
        "zh": "框架可覆盖成阅读角、秘密基地或夜间游戏小屋，适合家庭使用。"
      }
    },
    {
      "sectionTitle": {
        "en": "Space-Themed Gift Box",
        "zh": "太空主题礼品盒"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601730326005/3.webp",
      "text": {
        "en": "Moon-themed graphics strengthen the exploration story and help the product stand out in gift and e-commerce channels.",
        "zh": "月球主题画面强化探索故事，帮助产品在礼品和电商渠道中形成差异化。"
      }
    },
    {
      "sectionTitle": {
        "en": "Camping-Style Play",
        "zh": "露营风格玩法"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601730326005/4.webp",
      "text": {
        "en": "Outdoor night scenes make the set suitable for camping-themed promotions, yard play, and seasonal activity programs.",
        "zh": "户外夜间场景适合露营主题促销、庭院玩耍和季节活动项目。"
      }
    },
    {
      "sectionTitle": {
        "en": "Bedroom Glow Castle",
        "zh": "卧室夜光城堡"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1601730326005/5.webp",
      "text": {
        "en": "A luminous castle frame brings magic to indoor play and gives children a strong reason to rebuild the set after dark.",
        "zh": "发光城堡框架为室内玩耍增加梦幻感，也让儿童在夜间更愿意反复搭建。"
      }
    }
  ],
