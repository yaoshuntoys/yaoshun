  "productDetails": [
    {
      "sectionTitle": {
        "en": "Active Fort Play",
        "zh": "活动堡垒玩法"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1600898789412/1.webp",
      "text": {
        "en": "The arched fort format gives children enough room to crawl, reach, and play together while keeping the structure light and easy to move.",
        "zh": "拱形堡垒为儿童提供爬行、伸展和共同玩耍空间，同时结构轻便，便于移动。"
      }
    },
    {
      "sectionTitle": {
        "en": "Complete Color Kit",
        "zh": "完整彩色套装"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1600898789412/2.webp",
      "text": {
        "en": "Colorful poles, connector balls, and retail packaging create a lively shelf presentation for gift, education, and toy-store channels.",
        "zh": "彩色杆件、连接球和彩盒包装形成活泼货架视觉，适合礼品、教育和玩具零售渠道。"
      }
    },
    {
      "sectionTitle": {
        "en": "Vertical Castle Builds",
        "zh": "竖向城堡搭建"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1600898789412/3.webp",
      "text": {
        "en": "The same components can be rebuilt into taller castle shapes, helping children compare height, balance, and connection angles.",
        "zh": "同一套组件可重组为更高的城堡造型，帮助儿童理解高度、平衡和连接角度。"
      }
    },
    {
      "sectionTitle": {
        "en": "Low Stable Frames",
        "zh": "低矮稳定框架"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1600898789412/4.webp",
      "text": {
        "en": "Lower house structures are quick to assemble and suitable for younger children, classroom group work, and short activity sessions.",
        "zh": "低矮房屋结构搭建更快，适合低龄儿童、课堂小组活动和短时互动课程。"
      }
    },
    {
      "sectionTitle": {
        "en": "Reusable Plastic Poles",
        "zh": "可复用塑料杆件"
      },
      "type": "text",
      "image": "https://7j7davvujdsmddan.public.blob.vercel-storage.com/yaoshun-assets/products-q92/1600898789412/5.webp",
      "text": {
        "en": "Consistent pole cutting and smooth tube ends support repeated assembly, disassembly, and replacement planning for bulk orders.",
        "zh": "杆件切割一致、端面平滑，适合反复拼装拆卸，也便于批量订单的补件规划。"
      }
    }
  ],
